# Copy to .env.production on the VPS, set mode 600, and replace every value.
GATEWAY_DOMAIN=gateway.example.com
LETSENCRYPT_EMAIL=ops@example.com
CERTBOT_STAGING=0

POSTGRES_USER=gateway
POSTGRES_DB=gateway
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
# URL-encode reserved characters in the password used in this DSN.
DATABASE_URL=postgres://gateway:replace-with-a-long-random-postgres-password@postgres:5432/gateway?sslmode=disable

REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_MAXMEMORY=256mb
API_KEY_PEPPER=replace-with-at-least-32-random-characters

# Tailscale/private-network origins or private same-host services.
USER_SERVICE_URL=http://upstream-host.tailnet.example:8081
ORDER_SERVICE_URL=http://upstream-host.tailnet.example:8082

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password

USAGE_QUEUE_CAPACITY=4096
USAGE_BATCH_SIZE=200
USAGE_FLUSH_INTERVAL=1s
USAGE_MAX_ATTEMPTS=4
USAGE_RETRY_BASE_DELAY=100ms
USAGE_SHUTDOWN_TIMEOUT=10s

# Local backup files older than this are removed after a successful backup.
BACKUP_RETENTION_DAYS=14
